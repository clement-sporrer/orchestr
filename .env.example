# =============================================================================
# ORCHESTR - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# See docs/deployment.md for detailed setup instructions
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------

# PostgreSQL connection via PgBouncer (Transaction mode - port 6543)
# Used by the application for all database operations
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# PostgreSQL direct connection (Session mode - port 5432)
# Used only for migrations (npx prisma migrate)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# SUPABASE (Required)
# -----------------------------------------------------------------------------

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase anonymous key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -----------------------------------------------------------------------------
# APPLICATION (Required for production)
# -----------------------------------------------------------------------------

# Your application URL (used for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# -----------------------------------------------------------------------------
# AI FEATURES (Optional)
# -----------------------------------------------------------------------------

# OpenAI API key for AI features (scoring, messages, structuring)
OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# BILLING (Optional)
# -----------------------------------------------------------------------------

# Stripe secret key
STRIPE_SECRET_KEY="sk_live_..."

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe price IDs for subscription plans
STRIPE_PRICE_CORE_4WEEKS="price_..."
STRIPE_PRICE_CORE_ANNUAL="price_..."
STRIPE_PRICE_PRO_4WEEKS="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."

# -----------------------------------------------------------------------------
# SECURITY (Optional)
# -----------------------------------------------------------------------------

# Encryption key for sensitive data (64 hex characters = 256 bits)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-character-hex-string"

# Token for health check endpoint protection
# Generate with: openssl rand -base64 32
HEALTH_CHECK_TOKEN="your-health-check-token"

# -----------------------------------------------------------------------------
# INTEGRATIONS (Optional)
# -----------------------------------------------------------------------------

# Calendly webhook secret (if using Calendly integration)
# CALENDLY_WEBHOOK_SECRET="..."

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# -----------------------------------------------------------------------------

# Set to 'development' for local development, 'production' for prod
NODE_ENV="development"
