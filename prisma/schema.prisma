// ORCHESTR - Recruitment Orchestration Platform
// Complete database schema for MVP 1

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // Include binaries for local dev (native) and Vercel/AWS Lambda (rhel-openssl-3.0.x)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ORGANIZATION & USERS
// ============================================

model Organization {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String?   @unique // PRD v2: for clean URLs e.g. orchestr.app/paul-recrutement
  logo                  String?
  contactEmail          String?
  defaultCalendlyLink   String?
  retentionDaysIgnored  Int      @default(90)
  retentionDaysActive   Int      @default(365)
  onboardingCompleted   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users                User[]
  clients              Client[]
  missions             Mission[]
  candidates           Candidate[]
  pools                Pool[]
  events               Event[]
  subscription         Subscription?
  reportTemplates      ReportTemplate[]
  taxonomyPoles        TaxonomyPole[]
  taxonomyPositions    TaxonomyPosition[]
  settings             OrganizationSettings?

  @@map("organizations")
}

// Organization Settings - Configurable lists (PRD v2.0)
model OrganizationSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique

  // Candidates & Missions
  domains        String[] @default(["Leasing", "Crédit Consommation", "Informatique", "M&A", "Finance"])
  sectors        String[] @default(["Courtier/Loueur", "Captive", "Établissement Financier", "Asset Management", "Banque"])
  jobFamilies    String[] @default(["Commercial", "Manager Commercial", "Direction", "Support", "Technique"])

  // Clients (PRD v2)
  clientCategories String[] @default(["Loueur", "Établissement Financier", "Industriel", "Startup", "Corporate"])

  // Missions (PRD v2)
  contractTypes  String[] @default(["CDI", "CDD", "Freelance", "Stage", "Alternance"])
  seniorities    String[] @default(["1-5 ans", "5-10 ans", "10-20 ans", "20+ ans"])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_settings")
}

// ============================================
// BILLING & SUBSCRIPTIONS
// ============================================

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  stripeCustomerId       String             @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  plan                   Plan               @default(CORE)
  billingPeriod          BillingPeriod      @default(FOUR_WEEKS)
  status                 SubscriptionStatus @default(TRIALING)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}

enum Plan {
  CORE
  PRO
  WHITE_LABEL
}

enum BillingPeriod {
  FOUR_WEEKS
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  authUserId     String?  @unique @map("auth_user_id") @db.Uuid
  email          String   @unique
  name           String
  role           UserRole @default(RECRUITER)
  avatarUrl      String?
  
  // LinkedIn OAuth (encrypted)
  linkedinConnected     Boolean   @default(false)
  linkedinAccessToken   String?   // Encrypted
  linkedinRefreshToken  String?   // Encrypted
  linkedinExpiresAt     DateTime?
  linkedinCookies       Json?     // Session cookies (encrypted)
  linkedinLastUsed      DateTime?
  linkedinRequestCount  Int       @default(0) // Request counter (reset hourly)
  linkedinLastReset     DateTime? // Last counter reset
  linkedinRiskLevel     String?   // 'low', 'medium', 'high', 'blocked'
  linkedinBlockedUntil  DateTime? // If temporarily blocked
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedMissions    Mission[]
  interactions        Interaction[]
  tasks               Task[]
  messageTemplates    MessageTemplate[]

  @@index([organizationId])
  @@index([linkedinConnected])
  @@index([linkedinRiskLevel])
  @@map("users")
}

enum UserRole {
  ADMIN
  RECRUITER
}

// ============================================
// TAXONOMY (Poles, Positions)
// ============================================

model TaxonomyPole {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  positions    TaxonomyPosition[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("taxonomy_poles")
}

model TaxonomyPosition {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String
  poleId         String   @db.Uuid
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pole         TaxonomyPole        @relation(fields: [poleId], references: [id], onDelete: Cascade)
  candidates   CandidatePosition[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([poleId])
  @@map("taxonomy_positions")
}

model CandidatePosition {
  id          String   @id @default(uuid()) @db.Uuid
  candidateId String
  positionId  String   @db.Uuid
  createdAt   DateTime @default(now())

  candidate Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  position  TaxonomyPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([candidateId, positionId])
  @@index([candidateId])
  @@index([positionId])
  @@map("candidate_positions")
}

// ============================================
// CLIENT CRM
// ============================================

model Client {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // Legacy; PRD v2 uses companyName (display: companyName ?? name)
  companyName    String?  // PRD v2: normalized UPPERCASE
  category       String?  // PRD v2: from OrganizationSettings.clientCategories
  sector         String?
  website        String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  missions     Mission[]
  documents    ClientDocument[]

  @@index([organizationId])
  @@index([companyName])
  @@map("clients")
}

model Contact {
  id         String   @id @default(cuid())
  clientId   String
  firstName  String?
  lastName   String?
  title      String?
  email      String?
  phone      String?
  notes      String?
  isPrimary  Boolean  @default(false) // PRD v2: default contact for new missions
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  missionsAsMain  Mission[] @relation("MainContact")

  @@index([clientId])
  @@index([email])
  @@map("contacts")
}

// ============================================
// MISSIONS & JOB BUILDER
// ============================================

model Mission {
  id                String        @id @default(cuid())
  organizationId    String
  clientId          String
  mainContactId     String?       // PRD v2: Contact principal mission
  recruiterId       String?
  status            MissionStatus @default(ACTIVE)

  // Job details
  title             String
  jobTitle          String?       // PRD v2 alias (display: jobTitle ?? title)
  jobFamily         String?       // PRD v2: from Settings
  location          String?
  city              String?
  country           String?
  isRemote          Boolean       @default(false) // PRD v2
  contractType      ContractType?
  seniority         Seniority?
  seniorityLabel    String?       // PRD v2: from Settings e.g. "5-10 ans"
  salaryMin         Int?
  salaryMax         Int?
  salaryNotes       String?       @db.Text // PRD v2
  salaryVisible     Boolean       @default(false)
  currency          String        @default("EUR")
  domain            String?       // PRD v2: from Settings
  sector            String?       // PRD v2: from Settings (mission-level)
  languages         Json?         // PRD v2: [{lang, level}]
  priority          MissionPriority @default(MEDIUM)
  startDate         DateTime?
  deadline          DateTime?    // PRD v2
  shortlistDeadline DateTime?

  // Content sections with visibility
  context           String?
  contextVisibility Visibility    @default(INTERNAL)
  responsibilities     String?
  responsibilitiesVisibility Visibility @default(ALL)
  mustHave          String?
  mustHaveVisibility Visibility   @default(ALL)
  niceToHave        String?
  niceToHaveVisibility Visibility @default(ALL)
  redFlags          String?
  process           String?
  processVisibility Visibility    @default(INTERNAL_CLIENT)
  internalNotes     String?       @db.Text // PRD v2
  recruitmentProcess String?      @db.Text // PRD v2 alias

  // Calendly (out of scope v2, kept for compat)
  calendlyLink      String?
  calendlyEmbed     Boolean       @default(false)
  scoreThreshold    Int           @default(60)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mainContact          Contact?              @relation("MainContact", fields: [mainContactId], references: [id], onDelete: SetNull)
  recruiter            User?                 @relation(fields: [recruiterId], references: [id], onDelete: SetNull)
  missionCandidates    MissionCandidate[]
  questionnaire        Questionnaire?
  shortlists           Shortlist[]
  documents            MissionDocument[]

  @@index([organizationId])
  @@index([clientId])
  @@index([mainContactId])
  @@index([recruiterId])
  @@index([status])
  @@index([jobTitle])
  // Composite indexes for filtered queries (performance optimization)
  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([clientId, status])
  @@map("missions")
}

enum MissionStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  CLOSED_FILLED
  CLOSED_CANCELLED
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  INTERNSHIP
  APPRENTICESHIP
  OTHER
}

enum Seniority {
  JUNIOR
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum Visibility {
  INTERNAL           // Only recruiter
  INTERNAL_CLIENT    // Recruiter + client
  INTERNAL_CANDIDATE // Recruiter + candidate
  ALL                // Everyone
}

// ============================================
// CANDIDATES (TALENT CRM)
// ============================================

// RelationshipLevel: Global maturity of relationship between org and candidate
// This is not mission-specific, it tracks the overall relationship progression
enum RelationshipLevel {
  SOURCED     // Initial discovery, no contact yet
  CONTACTED   // First outreach made
  ENGAGED     // Active dialogue established
  QUALIFIED   // Skills and fit validated
  SHORTLISTED // Presented to clients
  PLACED      // Successfully placed in a role
}

// Candidate Seniority brackets (years of experience)
enum CandidateSeniority {
  ONE_TO_FIVE      // 1-5 ans
  FIVE_TO_TEN      // 5-10 ans
  TEN_TO_TWENTY    // 10-20 ans
  TWENTY_PLUS      // 20+ ans
}

// Candidate recruitable status
enum RecruitableStatus {
  YES
  NO
  UNKNOWN // Empty value represented as UNKNOWN
}

// Language proficiency levels
enum LanguageLevel {
  BEGINNER      // Débutant
  INTERMEDIATE  // Intermédiaire
  FLUENT        // Courant
  NATIVE        // Natif
}

model Candidate {
  id             String          @id @default(cuid())
  organizationId String
  
  // ========== IDENTITY (Champs 1-3) ==========
  // #1 id - Auto-generated above
  // #2 lastName - Auto-transformed to UPPERCASE
  lastName       String
  // #3 firstName - Auto-transformed to Capitalized
  firstName      String
  
  // ========== CONTACT (Champs 4-7) ==========
  // #4 email - Validated format, optional
  email          String?
  // #5 linkedin - Validated LinkedIn URL format, optional
  linkedin       String?
  // #6 phone - Country code + number stored as single string
  phone          String?
  // #7 age - Integer range 18-99, optional
  age            Int?
  
  // ========== LOCALISATION (Champs 8-10) ==========
  // #8 country - Normalized country name (ISO 3166-1)
  country        String?
  // #9 city - Normalized city name, filtered by country
  city           String?
  // #10 region - Auto-filled based on city/country
  region         String?
  
  // ========== COMPÉTENCES LINGUISTIQUES (Champ 11) ==========
  // #11 languages - JSON array [{lang: string, level: enum}]
  languages      Json?  // Array of {language: string, level: LanguageLevel}
  
  // ========== EXPÉRIENCE PROFESSIONNELLE (Champs 12-18) ==========
  // #12 seniority - Experience bracket (1-5, 5-10, 10-20, 20+)
  seniority      CandidateSeniority?
  // #13 domain - User-defined configurable list (from OrganizationSettings)
  domain         String?
  // #14 sector - User-defined configurable list (from OrganizationSettings)
  sector         String?
  // #15 currentCompany - Auto-suggest from existing, transformed to MAJ
  currentCompany String?
  // #16 currentPosition - Auto-suggest from existing, transformed to MAJ
  currentPosition String?
  // #17 pastCompanies - Semicolon-separated list
  pastCompanies  String?
  // #18 jobFamily - User-defined configurable list (from OrganizationSettings)
  jobFamily      String?
  
  // ========== COMPÉTENCES (Champs 19-20) ==========
  // #19 hardSkills - Semicolon-separated list
  hardSkills     String?
  // #20 softSkills - Semicolon-separated list
  softSkills     String?
  
  // ========== INFORMATIONS ADDITIONNELLES (Champs 21-24) ==========
  // #21 compensation - Free-form multi-line text
  compensation   String?
  // #22 comments - Free-form internal notes
  comments       String?
  // #23 references - Free-form contacts/referents
  references     String?
  // #24 recruitable - YES / NO / UNKNOWN (empty = UNKNOWN)
  recruitable    RecruitableStatus @default(UNKNOWN)
  
  // ========== FICHIERS (Champ 25) ==========
  // #25 files - Array of file paths in Supabase Storage
  files          String[]        @default([])
  
  // ========== MÉTADONNÉES SYSTÈME (Champs 26-28) ==========
  // #26 solicitationHistory - Auto-tracked JSON array
  solicitationHistory Json?  // Array of {date, action, missionId, missionName}
  // #27 createdAt - Auto timestamp
  createdAt      DateTime        @default(now())
  // #28 updatedAt - Auto timestamp
  updatedAt      DateTime        @updatedAt
  
  // ========== LEGACY FIELDS (kept for backward compatibility) ==========
  cvUrl            String?         // Legacy CV URL (use files array)
  location         String?         // Legacy location (use country/city/region)
  
  // Relationship level (global, not mission-specific)
  relationshipLevel RelationshipLevel @default(SOURCED)
  
  // Tags and status
  tags           String[]        @default([])
  status         CandidateStatus @default(ACTIVE)

  // Consent
  consentGiven     Boolean       @default(false)
  consentDate      DateTime?
  consentText      String?
  
  // Deduplication tracking
  mergedFromIds    String[]      @default([])

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  missionCandidates    MissionCandidate[]
  interactions         Interaction[]
  poolMemberships      CandidatePool[]
  enrichment           CandidateEnrichment?
  positions            CandidatePosition[]
  documents            CandidateDocument[]

  // Note: partial unique index (email IS NOT NULL) is managed via raw migration
  // prisma/migrations/20260328000000_fix_candidate_email_null_unique/migration.sql
  @@index([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([phone])
  @@index([linkedin])
  @@index([status])
  @@index([relationshipLevel])
  @@index([lastName, firstName])
  @@index([currentCompany])
  @@index([currentPosition])
  @@index([seniority])
  @@index([domain])
  @@index([sector])
  @@index([recruitable])
  // Composite indexes for filtered queries (performance optimization)
  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, relationshipLevel, updatedAt(sort: Desc)])
  @@map("candidates")
}

enum CandidateStatus {
  ACTIVE
  TO_RECONTACT
  BLACKLIST
  DELETED  // For GDPR soft delete
}

// ============================================
// CANDIDATE ENRICHMENT (LinkedIn Data)
// ============================================

model CandidateEnrichment {
  id                  String   @id @default(cuid())
  candidateId         String   @unique
  
  // LinkedIn data
  linkedinUrl         String?
  linkedinHeadline    String?
  linkedinSummary     String?
  linkedinConnections Int?
  
  // Structured data
  experiences         Json?    // Array of {company, title, startDate, endDate, description}
  education           Json?    // Array of {school, degree, field, year}
  skills              String[] @default([])
  languages           String[] @default([])
  certifications      String[] @default([])
  
  // Metadata
  lastEnrichedAt      DateTime?
  enrichmentSource    String?  // "chrome_extension", "manual", "api", "scraper"
  rawData             Json?    // Raw data for reprocessing
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  @@index([linkedinUrl])
  @@map("candidate_enrichments")
}

// ============================================
// LINKEDIN CACHE (to avoid repeated requests)
// ============================================

model LinkedInCache {
  id          String   @id @default(cuid())
  linkedinUrl String   @unique
  data        Json
  cachedAt    DateTime @default(now())
  expiresAt   DateTime
  
  @@index([linkedinUrl])
  @@index([expiresAt])
  @@map("linkedin_cache")
}

// ============================================
// PIPELINE (MissionCandidate = Application bridge)
// ============================================

model MissionCandidate {
  id           String        @id @default(cuid())
  missionId    String
  candidateId  String

  stage        PipelineStage @default(SOURCED)
  contactStatus ContactStatus @default(NOT_CONTACTED)

  // PRD v2: notes & feedback
  internalNotes  String?      @db.Text
  clientFeedback String?      @db.Text

  // PRD v2: tracking dates (set on stage transitions)
  contactedAt     DateTime?
  interviewDate   DateTime?
  sentToClientAt DateTime?
  hiredAt        DateTime?
  rejectedAt     DateTime?
  rejectionReason String?     @db.Text

  // Scoring (out of scope v2, kept for compat)
  score        Int?
  scoreReasons String[]      @default([])
  portalToken      String?   @unique
  portalTokenExpiry DateTime?
  portalCompleted  Boolean   @default(false)
  portalStep       Int       @default(0)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  mission                Mission                 @relation(fields: [missionId], references: [id], onDelete: Cascade)
  candidate              Candidate               @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interactions           Interaction[]
  questionnaireResponses QuestionnaireResponse[]
  shortlistCandidates    ShortlistCandidate[]
  interviews             Interview[]
  documents              CandidateMissionDocument[]
  tasks                  Task[]

  @@unique([missionId, candidateId])
  @@index([missionId])
  @@index([candidateId])
  @@index([stage])
  @@index([missionId, stage])
  // Composite indexes for pipeline queries (performance optimization)
  @@index([candidateId, stage, updatedAt(sort: Desc)])
  @@index([missionId, stage, updatedAt(sort: Desc)])
  @@map("mission_candidates")
}

enum PipelineStage {
  SOURCED           // sourcé — initial discovery
  CONTACTED         // contacté — first outreach made
  RESPONSE          // réponse — candidate replied
  INTERVIEW         // entretien — interview phase (scheduled or done)
  SHORTLIST         // shortlist — presented to client
  OFFER             // offre — offer extended
  PLACED            // placé — successfully hired
}

enum ContactStatus {
  NOT_CONTACTED
  NO_RESPONSE
  OPEN
  CLOSED
  LATER
}

// ============================================
// DOCUMENTS (PRD v2.0 - Supabase Storage)
// ============================================

model ClientDocument {
  id        String   @id @default(cuid())
  clientId  String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_documents")
}

model MissionDocument {
  id           String   @id @default(cuid())
  missionId    String
  documentType String   // PROPOSAL, CONTRACT, JOB_DESC, PRESENTATION, OTHER
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  createdAt    DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([documentType])
  @@map("mission_documents")
}

model CandidateDocument {
  id          String   @id @default(cuid())
  candidateId String
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_documents")
}

model CandidateMissionDocument {
  id                  String   @id @default(cuid())
  missionCandidateId  String
  documentType        String   // INTERNAL_REPORT, CLIENT_REPORT, OTHER
  fileName            String
  fileUrl             String
  fileType            String
  fileSize            Int
  createdAt           DateTime @default(now())

  missionCandidate MissionCandidate @relation(fields: [missionCandidateId], references: [id], onDelete: Cascade)

  @@index([missionCandidateId])
  @@map("candidate_mission_documents")
}

// ============================================
// POOLS
// ============================================

model Pool {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidates   CandidatePool[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("pools")
}

model CandidatePool {
  id          String   @id @default(cuid())
  candidateId String
  poolId      String
  addedAt     DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  pool      Pool      @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([candidateId, poolId])
  @@index([candidateId])
  @@index([poolId])
  @@map("candidate_pools")
}

// ============================================
// INTERACTIONS & TASKS
// ============================================

model Interaction {
  id                  String           @id @default(cuid())
  organizationId      String
  candidateId         String
  missionCandidateId  String?
  userId              String?
  
  type                InteractionType
  content             String?
  
  // For scheduled interactions
  scheduledAt         DateTime?
  completedAt         DateTime?
  
  // Calendly data
  calendlyEventId     String?
  calendlyEventUrl    String?
  
  // Message tracking (for LinkedIn/Email messages)
  messageFormat       MessageFormat?
  messageContent      String?
  messageCopiedAt     DateTime?
  
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  candidate         Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  missionCandidate  MissionCandidate? @relation(fields: [missionCandidateId], references: [id], onDelete: SetNull)
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([candidateId])
  @@index([missionCandidateId])
  @@index([userId])
  @@index([type])
  @@map("interactions")
}

enum InteractionType {
  MESSAGE
  EMAIL
  CALL
  INTERVIEW_SCHEDULED
  INTERVIEW_DONE
  NOTE
  PORTAL_COMPLETED
  PORTAL_INVITED
  CLIENT_FEEDBACK
  STATUS_CHANGE
}

enum MessageFormat {
  LINKEDIN_CONNECTION
  LINKEDIN_INMAIL
  EMAIL
}

model Task {
  id                  String        @id @default(cuid())
  userId              String
  missionCandidateId  String?
  
  title               String
  description         String?
  priority            TaskPriority  @default(MEDIUM)
  dueDate             DateTime?
  completedAt         DateTime?
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionCandidate MissionCandidate? @relation(fields: [missionCandidateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dueDate])
  @@index([completedAt])
  @@index([missionCandidateId])
  @@map("tasks")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MissionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// MESSAGE TEMPLATES
// ============================================

model MessageTemplate {
  id             String              @id @default(cuid())
  userId         String
  type           MessageTemplateType
  name           String
  subject        String?
  content        String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("message_templates")
}

enum MessageTemplateType {
  INITIAL_CONTACT
  FOLLOW_UP
  REJECTION
  INTERVIEW_CONFIRMATION
  CUSTOM
}

// ============================================
// QUESTIONNAIRES
// ============================================

model Questionnaire {
  id          String   @id @default(cuid())
  missionId   String   @unique
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mission   Mission              @relation(fields: [missionId], references: [id], onDelete: Cascade)
  questions QuestionnaireQuestion[]
  responses QuestionnaireResponse[]

  @@map("questionnaires")
}

model QuestionnaireQuestion {
  id              String       @id @default(cuid())
  questionnaireId String
  
  text            String
  type            QuestionType
  options         String[]     @default([])  // For choice questions
  required        Boolean      @default(false)
  shareableWithClient Boolean  @default(false)
  order           Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  questionnaire Questionnaire           @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers       QuestionnaireAnswer[]

  @@index([questionnaireId])
  @@map("questionnaire_questions")
}

enum QuestionType {
  TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  NUMBER
  DATE
}

model QuestionnaireResponse {
  id                  String   @id @default(cuid())
  questionnaireId     String
  missionCandidateId  String
  submittedAt         DateTime @default(now())

  questionnaire    Questionnaire           @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  missionCandidate MissionCandidate        @relation(fields: [missionCandidateId], references: [id], onDelete: Cascade)
  answers          QuestionnaireAnswer[]

  @@unique([questionnaireId, missionCandidateId])
  @@index([questionnaireId])
  @@index([missionCandidateId])
  @@map("questionnaire_responses")
}

model QuestionnaireAnswer {
  id          String   @id @default(cuid())
  responseId  String
  questionId  String
  value       String   // JSON string for complex answers
  createdAt   DateTime @default(now())

  response QuestionnaireResponse  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question QuestionnaireQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@index([responseId])
  @@index([questionId])
  @@map("questionnaire_answers")
}

// ============================================
// INTERVIEWS & REPORTS
// ============================================

model Interview {
  id                  String           @id @default(cuid())
  missionCandidateId  String
  
  // Scheduling
  scheduledAt         DateTime
  duration            Int              @default(45)  // minutes
  type                InterviewType
  location            String?
  meetingUrl          String?
  
  // Status
  status              InterviewStatus  @default(SCHEDULED)
  startedAt           DateTime?
  endedAt             DateTime?
  
  // Transcript
  transcriptSource    TranscriptSource?
  transcriptUrl       String?
  transcriptText      String?
  transcriptLanguage  String?          @default("fr")
  
  // Notes and report
  recruiterNotes      String?
  reportTemplateId    String?
  reportContent       String?
  reportGeneratedAt   DateTime?
  
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  
  missionCandidate MissionCandidate @relation(fields: [missionCandidateId], references: [id], onDelete: Cascade)
  reportTemplate   ReportTemplate?  @relation(fields: [reportTemplateId], references: [id], onDelete: SetNull)
  
  @@index([missionCandidateId])
  @@index([scheduledAt])
  @@index([status])
  @@map("interviews")
}

enum InterviewType {
  PHONE_SCREEN
  VIDEO_RECRUITER
  VIDEO_CLIENT
  ONSITE
}

enum InterviewStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TranscriptSource {
  MANUAL
  GOOGLE_MEET
  ZOOM
  TEAMS
  OTHER
}

model ReportTemplate {
  id              String     @id @default(cuid())
  organizationId  String
  
  name            String
  type            ReportType
  sections        Json       // [{title, prompt, required, order}]
  isDefault       Boolean    @default(false)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  interviews   Interview[]
  
  @@index([organizationId])
  @@index([type])
  @@map("report_templates")
}

enum ReportType {
  INDIVIDUAL
  SHORTLIST
  CLIENT_SUMMARY
}

// ============================================
// CLIENT SHORTLIST & FEEDBACK
// ============================================

model Shortlist {
  id          String   @id @default(cuid())
  missionId   String
  name        String
  
  // Access token for client portal (stores SHA-256 hash — raw token never persisted)
  accessToken       String   @unique
  accessTokenExpiry DateTime?
  // Full client portal URL stored at creation time (raw token is discarded after hashing)
  clientPortalUrl   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mission    Mission              @relation(fields: [missionId], references: [id], onDelete: Cascade)
  candidates ShortlistCandidate[]

  @@index([missionId])
  @@map("shortlists")
}

model ShortlistCandidate {
  id                  String   @id @default(cuid())
  shortlistId         String
  missionCandidateId  String
  order               Int      @default(0)
  summary             String?  // Custom summary for client
  createdAt           DateTime @default(now())

  shortlist        Shortlist        @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  missionCandidate MissionCandidate @relation(fields: [missionCandidateId], references: [id], onDelete: Cascade)
  feedback         ClientFeedback?

  @@unique([shortlistId, missionCandidateId])
  @@index([shortlistId])
  @@index([missionCandidateId])
  @@map("shortlist_candidates")
}

model ClientFeedback {
  id                    String         @id @default(cuid())
  shortlistCandidateId  String         @unique
  
  decision              FeedbackDecision
  comment               String?
  
  submittedAt           DateTime       @default(now())

  shortlistCandidate ShortlistCandidate @relation(fields: [shortlistCandidateId], references: [id], onDelete: Cascade)

  @@map("client_feedbacks")
}

enum FeedbackDecision {
  OK
  TO_DISCUSS
  NO
}

// ============================================
// CSV IMPORT TRACKING
// ============================================

model CsvImport {
  id             String          @id @default(cuid())
  organizationId String
  
  fileName       String
  destination    ImportDestination
  destinationId  String?         // poolId or missionId if applicable
  
  status         ImportStatus    @default(PENDING)
  
  // Stats
  totalRows      Int             @default(0)
  newCount       Int             @default(0)
  updatedCount   Int             @default(0)
  mergedCount    Int             @default(0)
  ignoredCount   Int             @default(0)
  errorCount     Int             @default(0)
  
  // For rollback
  affectedCandidateIds String[]  @default([])
  rollbackAvailableUntil DateTime?
  
  mapping        Json?           // Column mapping used
  errors         Json?           // Error details
  
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  @@index([organizationId])
  @@index([status])
  @@map("csv_imports")
}

enum ImportDestination {
  VIVIER      // Global talent pool
  POOL        // Specific pool
  MISSION     // Specific mission
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ROLLED_BACK
}

// ============================================
// ANALYTICS & EVENTS
// ============================================

model Event {
  id             String   @id @default(cuid())
  organizationId String
  
  name           String
  properties     Json?
  
  // Context
  userId         String?
  candidateId    String?
  missionId      String?
  
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([name])
  @@index([createdAt])
  @@index([userId])
  @@index([missionId])
  @@map("events")
}
